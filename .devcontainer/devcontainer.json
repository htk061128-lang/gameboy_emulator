{
  "name": "GameBoy Emulator Dev",
  "image": "mcr.microsoft.com/devcontainers/cpp:1-ubuntu-22.04",
  "forwardPorts": [6080],
  "features": {
    "ghcr.io/devcontainers/features/desktop-lite:1": {
      "password": "vncpassword"
    }
  },
  "postCreateCommand": "sudo apt-get update && sudo apt-get install -y verilator libsdl2-dev libsdl2-image-dev libsdl2-ttf-dev build-essential",
  "customizations": {
    "vscode": {
      "extensions": [
        "mshr-h.VerilogHDL",
        "ms-vscode.cpptools",
        "ms-vscode.cpptools-extension-pack"
      ] 
    }
  }
}
